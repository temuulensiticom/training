@page
@model IndexModel
@{
    ViewData["Title"] = "SQL File Executor";
}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8 offset-lg-2">
            <h1 class="mb-4">Database SQL File Executor</h1>

            <!-- Database Status -->
            <div class="row mb-4">
                <div class="col-md-6">
                    <div class="card @(Model.Database1Connected ? "border-success" : "border-danger")">
                        <div class="card-body">
                            <h5 class="card-title">Database 1 (Port 3308)</h5>
                            <p class="card-text">
                                Status: 
                                @if (Model.Database1Connected)
                                {
                                    <span class="badge bg-success">Connected</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Disconnected</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card @(Model.Database2Connected ? "border-success" : "border-danger")">
                        <div class="card-body">
                            <h5 class="card-title">Database 2 (Port 3309)</h5>
                            <p class="card-text">
                                Status: 
                                @if (Model.Database2Connected)
                                {
                                    <span class="badge bg-success">Connected</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Disconnected</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- File Upload Form -->
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Upload SQL File</h5>
                </div>
                <div class="card-body">
                    <form method="post" enctype="multipart/form-data">
                        <div class="mb-3">
                            <label for="fileInput" class="form-label">Select SQL or Text File:</label>
                            <input type="file" class="form-control" id="fileInput" name="fileUpload" accept=".sql,.txt" required>
                            <small class="form-text text-muted">Allowed formats: .sql, .txt (Max 5MB)</small>
                        </div>

                        <div class="mb-3">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="db1Check" name="executeOnDb1" value="true" checked>
                                <label class="form-check-label" for="db1Check">
                                    Execute on Database 1 (Port 3308)
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="db2Check" name="executeOnDb2" value="true" checked>
                                <label class="form-check-label" for="db2Check">
                                    Execute on Database 2 (Port 3309)
                                </label>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary btn-lg w-100">Upload & Execute</button>
                    </form>
                </div>
            </div>

            <!-- Messages -->
            @if (!string.IsNullOrEmpty(Model.Message))
            {
                <div class="alert @(Model.HasError ? "alert-danger" : "alert-success") alert-dismissible fade show" role="alert">
                    @Html.Raw(Model.Message)
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (Model.IsDuplicate && !string.IsNullOrEmpty(Model.DuplicateMessage))
            {
                <div class="alert alert-warning alert-dismissible fade show" role="alert">
                    <strong>Duplicate File:</strong> @Model.DuplicateMessage
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            <!-- Execution Results -->
            @if (Model.Database1Results != null)
            {
                <div class="card mb-4 mt-4">
                    <div class="card-header @(Model.Database1Results.Error != "" ? "bg-danger" : "bg-info") text-white">
                        <h5 class="mb-0">@Model.Database1Results.DatabaseName</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.Database1Results.Error))
                        {
                            <div class="alert alert-danger">
                                <strong>Connection Error:</strong> @Model.Database1Results.Error
                            </div>
                        }
                        else
                        {
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <strong>Successful Queries:</strong>
                                    <span class="badge bg-success">@Model.Database1Results.SuccessfulQueries</span>
                                </div>
                                <div class="col-md-3">
                                    <strong>Failed Queries:</strong>
                                    <span class="badge bg-danger">@Model.Database1Results.FailedQueries</span>
                                </div>
                                <div class="col-md-3">
                                    <strong>Duplicate Errors:</strong>
                                    <span class="badge bg-warning">@Model.Database1Results.DuplicateErrors</span>
                                </div>
                            </div>

                            <h6>Query Details:</h6>
                            <div class="bg-light p-3 rounded" style="max-height: 300px; overflow-y: auto;">
                                <ul class="list-unstyled">
                                    @foreach (var detail in Model.Database1Results.Details)
                                    {
                                        <li>@Html.Raw(detail)</li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            }

            @if (Model.Database2Results != null)
            {
                <div class="card mb-4">
                    <div class="card-header @(Model.Database2Results.Error != "" ? "bg-danger" : "bg-info") text-white">
                        <h5 class="mb-0">@Model.Database2Results.DatabaseName</h5>
                    </div>
                    <div class="card-body">
                        @if (!string.IsNullOrEmpty(Model.Database2Results.Error))
                        {
                            <div class="alert alert-danger">
                                <strong>Connection Error:</strong> @Model.Database2Results.Error
                            </div>
                        }
                        else
                        {
                            <div class="row mb-3">
                                <div class="col-md-3">
                                    <strong>Successful Queries:</strong>
                                    <span class="badge bg-success">@Model.Database2Results.SuccessfulQueries</span>
                                </div>
                                <div class="col-md-3">
                                    <strong>Failed Queries:</strong>
                                    <span class="badge bg-danger">@Model.Database2Results.FailedQueries</span>
                                </div>
                                <div class="col-md-3">
                                    <strong>Duplicate Errors:</strong>
                                    <span class="badge bg-warning">@Model.Database2Results.DuplicateErrors</span>
                                </div>
                            </div>

                            <h6>Query Details:</h6>
                            <div class="bg-light p-3 rounded" style="max-height: 300px; overflow-y: auto;">
                                <ul class="list-unstyled">
                                    @foreach (var detail in Model.Database2Results.Details)
                                    {
                                        <li>@Html.Raw(detail)</li>
                                    }
                                </ul>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
